{
  "name": "mess-auth-system",
  "version": "1.0.0",
  "private": true,
  "description": "Dual Mess Subscription Enforcement System with Dynamic QR Authorization",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "setup": "node scripts/create-auth-users.js",
    "setup:reset": "node scripts/create-auth-users.js --reset",
    "check": "node scripts/db-check.js",
    "icons": "node scripts/generate-icons.js",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db push --include-all",
    "db:types": "supabase gen types typescript --local > src/types/database.ts",
    "db:reset": "supabase db reset",
    "vercel:env": "vercel env pull .env.local"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "html5-qrcode": "^2.3.8",
    "next": "15.2.9",
    "nodemailer": "^8.0.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.23.0",
    "eslint-config-next": "15.2.9",
    "postcss": "^8.4.0",
    "supabase": "^2.77.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
