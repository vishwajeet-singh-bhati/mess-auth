# ============================================================
# MESS AUTH SYSTEM — Environment Variables
# ============================================================
# 1. Copy this file:       cp .env.example .env.local
# 2. Fill in your values
# 3. NEVER commit .env.local to version control
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Supabase Dashboard → Settings → API

# Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key (safe to expose — protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — SERVER ONLY, bypasses RLS. NEVER expose to browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── QR Token Signing ──────────────────────────────────────────
# HMAC-SHA256 secret for QR token signatures.
# Generate: openssl rand -hex 32
# Must be ≥32 characters. Keep SECRET.
QR_SIGNING_SECRET=replace-this-with-output-of-openssl-rand-hex-32

# ── Application ───────────────────────────────────────────────
# Your deployed URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# IANA timezone for meal slot evaluation
APP_TIMEZONE=Asia/Kolkata

# ── Cron Jobs ─────────────────────────────────────────────────
# Secret to authenticate Vercel cron requests
# Generate: openssl rand -hex 32
CRON_SECRET=replace-this-with-output-of-openssl-rand-hex-32

# ── Optional: Redis (distributed rate limiting) ───────────────
# Needed only if deploying with >1 Vercel region.
# Without this, in-memory rate limiting is used (fine for single region).
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# ── Optional: Email notifications ─────────────────────────────
# Used for mess change request approval/rejection emails.
# RESEND_API_KEY=re_...
# FROM_EMAIL=noreply@yourinstitute.edu
